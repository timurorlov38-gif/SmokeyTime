<UserControl x:Class="SmokeyTime.DashboardView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- Page Title -->
            <StackPanel Margin="0,0,0,30">
                <TextBlock Text="Панель управления" 
                           FontSize="28" 
                           FontWeight="Bold"
                           Foreground="#111827"/>
                <TextBlock Text="Обзор основных показателей магазина" 
                           FontSize="14"
                           Foreground="#6b7280"
                           Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Statistics Cards -->
            <Grid Margin="0,0,0,30">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Card 1: Sales Today -->
                <Border Grid.Column="0" 
                        Background="White" 
                        CornerRadius="10" 
                        Padding="20"
                        Margin="0,0,15,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" 
                                       Text="Продажи за сегодня" 
                                       FontSize="14"
                                       Foreground="#6b7280"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1" 
                                    Background="#dbeafe" 
                                    CornerRadius="8" 
                                    Width="32" 
                                    Height="32">
                                <Viewbox Width="18" Height="18">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="#3b82f6" 
                                              Data="M20,4H4A2,2 0 0,0 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6A2,2 0 0,0 20,4M20,18H4V8L12,13L20,8V18M12,11L4,6H20L12,11Z"/>
                                    </Canvas>
                                </Viewbox>
                            </Border>
                        </Grid>
                        <TextBlock Text="2" 
                                   FontSize="32" 
                                   FontWeight="Bold"
                                   Foreground="#111827"/>
                    </StackPanel>
                </Border>

                <!-- Card 2: Revenue Today -->
                <Border Grid.Column="1" 
                        Background="White" 
                        CornerRadius="10" 
                        Padding="20"
                        Margin="7.5,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" 
                                       Text="Выручка за сегодня" 
                                       FontSize="14"
                                       Foreground="#6b7280"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1" 
                                    Background="#d1fae5" 
                                    CornerRadius="8" 
                                    Width="32" 
                                    Height="32">
                                <Viewbox Width="18" Height="18">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="#10b981" 
                                              Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M11,14H13V16H11V14M12,7A2.5,2.5 0 0,1 14.5,9.5C14.5,11.43 11,12.24 11,13.5V14H13V13.5C13,12.89 13.58,12.5 14.08,12.29C14.93,11.93 15.5,11.39 15.5,10.5A3.5,3.5 0 0,0 12,7Z"/>
                                    </Canvas>
                                </Viewbox>
                            </Border>
                        </Grid>
                        <TextBlock Text="47 200 ₽" 
                                   FontSize="32" 
                                   FontWeight="Bold"
                                   Foreground="#111827"/>
                    </StackPanel>
                </Border>

                <!-- Card 3: Products in Stock -->
                <Border Grid.Column="2" 
                        Background="White" 
                        CornerRadius="10" 
                        Padding="20"
                        Margin="7.5,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" 
                                       Text="Товаров в наличии" 
                                       FontSize="14"
                                       Foreground="#6b7280"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1" 
                                    Background="#f3e8ff" 
                                    CornerRadius="8" 
                                    Width="32" 
                                    Height="32">
                                <Viewbox Width="18" Height="18">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="#a855f7" 
                                              Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L6.04,7.5L12,10.85L17.96,7.5L12,4.15M5,15.91L11,19.29V12.58L5,9.21V15.91M19,15.91V9.21L13,12.58V19.29L19,15.91Z"/>
                                    </Canvas>
                                </Viewbox>
                            </Border>
                        </Grid>
                        <TextBlock Text="6" 
                                   FontSize="32" 
                                   FontWeight="Bold"
                                   Foreground="#111827"/>
                    </StackPanel>
                </Border>

                <!-- Card 4: Low Stock -->
                <Border Grid.Column="3" 
                        Background="White" 
                        CornerRadius="10" 
                        Padding="20"
                        Margin="15,0,0,0">
                    <StackPanel>
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" 
                                       Text="Заканчивается" 
                                       FontSize="14"
                                       Foreground="#6b7280"
                                       VerticalAlignment="Center"/>
                            <Border Grid.Column="1" 
                                    Background="#fef3c7" 
                                    CornerRadius="8" 
                                    Width="32" 
                                    Height="32">
                                <Viewbox Width="18" Height="18">
                                    <Canvas Width="24" Height="24">
                                        <Path Fill="#f59e0b" 
                                              Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4C10.5,4 9.08,4.41 7.88,5.12L16.88,14.12C17.59,12.92 18,11.5 18,10A8,8 0 0,0 12,4M4,12C4,13.5 4.41,14.92 5.12,16.12L16.12,5.12C14.92,4.41 13.5,4 12,4A8,8 0 0,0 4,12Z"/>
                                    </Canvas>
                                </Viewbox>
                            </Border>
                        </Grid>
                        <TextBlock Text="1" 
                                   FontSize="32" 
                                   FontWeight="Bold"
                                   Foreground="#111827"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</UserControl>
