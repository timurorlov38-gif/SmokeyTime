<UserControl x:Class="SmokeyTime.SettingsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- Page Title -->
            <StackPanel Margin="0,0,0,25">
                <TextBlock Text="Настройки системы" FontSize="28" FontWeight="Bold" Foreground="#111827"/>
                <TextBlock Text="Конфигурация и администрирование" FontSize="14" Foreground="#6b7280" Margin="0,5,0,0"/>
            </StackPanel>

            <!-- Settings Content Card -->
            <Border Background="White" CornerRadius="10" Padding="30" BorderBrush="#e5e7eb" BorderThickness="1" Margin="0,0,0,20">
                <StackPanel>
                    <!-- Section Title -->
                    <StackPanel Margin="0,0,0,25">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Viewbox Width="24" Height="24" Margin="0,0,10,0">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="#1a253a" Data="M19.14,12.94C19.16,12.78 19.17,12.61 19.17,12.44C19.17,12.27 19.16,12.11 19.14,11.94L21.16,10.37C21.34,10.23 21.39,9.98 21.28,9.78L19.38,6.49C19.27,6.29 19.03,6.21 18.81,6.29L16.44,7.24C15.95,6.86 15.42,6.54 14.85,6.29L14.49,3.77C14.46,3.54 14.26,3.37 14.03,3.37H10.21C9.98,3.37 9.78,3.54 9.75,3.77L9.39,6.29C8.82,6.54 8.29,6.86 7.8,7.24L5.43,6.29C5.21,6.2 4.97,6.28 4.86,6.49L2.96,9.78C2.85,9.98 2.9,10.23 3.08,10.37L5.1,11.94C5.08,12.11 5.07,12.27 5.07,12.44C5.07,12.61 5.08,12.78 5.1,12.94L3.08,14.51C2.9,14.65 2.85,14.9 2.96,15.1L4.86,18.39C4.97,18.59 5.21,18.67 5.43,18.59L7.8,17.64C8.29,18.02 8.82,18.34 9.39,18.59L9.75,21.11C9.78,21.34 9.98,21.51 10.21,21.51H14.03C14.26,21.51 14.46,21.34 14.49,21.11L14.85,18.59C15.42,18.34 15.95,18.02 16.44,17.64L18.81,18.59C19.03,18.68 19.27,18.6 19.38,18.39L21.28,15.1C21.39,14.9 21.34,14.65 21.16,14.51L19.14,12.94M12.13,15.56C10.45,15.56 9.09,14.2 9.09,12.52C9.09,10.84 10.45,9.48 12.13,9.48C13.81,9.48 15.17,10.84 15.17,12.52C15.17,14.2 13.81,15.56 12.13,15.56Z"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Text="Основные настройки" FontSize="18" FontWeight="SemiBold" Foreground="#111827" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="Параметры работы системы" FontSize="14" Foreground="#6b7280"/>
                    </StackPanel>

                    <!-- Store Name Field -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Название магазина" FontSize="14" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,8"/>
                        <Border Background="#f3f4f6" CornerRadius="6" Padding="12,10">
                            <TextBox BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#111827" 
                                     VerticalContentAlignment="Center" Text="Smokey Time"/>
                        </Border>
                    </StackPanel>

                    <!-- Address Field -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Адрес" FontSize="14" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,8"/>
                        <Border Background="#f3f4f6" CornerRadius="6" Padding="12,10">
                            <TextBox BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#111827" 
                                     VerticalContentAlignment="Center" Text="г. Иркутск, ул. Ленина, д. 1"/>
                        </Border>
                    </StackPanel>

                    <!-- Phone Field -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Телефон" FontSize="14" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,8"/>
                        <Border Background="#f3f4f6" CornerRadius="6" Padding="12,10">
                            <TextBox BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#111827" 
                                     VerticalContentAlignment="Center" Text="+7 (XXX) XXX-XX-XX"/>
                        </Border>
                    </StackPanel>

                    <!-- Email Field -->
                    <StackPanel Margin="0,0,0,25">
                        <TextBlock Text="Email" FontSize="14" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,8"/>
                        <Border Background="#f3f4f6" CornerRadius="6" Padding="12,10">
                            <TextBox BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#111827" 
                                     VerticalContentAlignment="Center" Text="info@smokeytime.ru"/>
                        </Border>
                    </StackPanel>

                    <!-- Save Settings Button -->
                    <Button Content="Сохранить настройки" Click="SaveSettingsButton_Click"
                            Background="#1a253a" Foreground="White" Padding="25,12" BorderThickness="0" 
                            FontWeight="SemiBold" FontSize="14" Cursor="Hand" HorizontalAlignment="Left">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>

            <!-- Master Password Card -->
            <Border Background="White" CornerRadius="10" Padding="30" BorderBrush="#e5e7eb" BorderThickness="1">
                <StackPanel>
                    <!-- Section Title -->
                    <StackPanel Margin="0,0,0,25">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Viewbox Width="24" Height="24" Margin="0,0,10,0">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="#1a253a" Data="M12,17A2,2 0 0,0 14,15C14,13.89 13.1,13 12,13A2,2 0 0,0 10,15A2,2 0 0,0 12,17M18,8A2,2 0 0,1 20,10V20A2,2 0 0,1 18,22H6A2,2 0 0,1 4,20V10C4,8.89 4.9,8 6,8H7V6A5,5 0 0,1 12,1A5,5 0 0,1 17,6V8H18M12,3A3,3 0 0,0 9,6V8H15V6A3,3 0 0,0 12,3Z"/>
                                </Canvas>
                            </Viewbox>
                            <StackPanel>
                                <TextBlock Text="Мастер-пароль" FontSize="18" FontWeight="SemiBold" Foreground="#111827" VerticalAlignment="Center"/>
                                <TextBlock Text="Для доступа к критическим настройкам" FontSize="14" Foreground="#6b7280" Margin="0,2,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <!-- Current Password Field -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Текущий пароль" FontSize="14" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,8"/>
                        <Border Background="#f3f4f6" CornerRadius="6" Padding="12,10">
                            <PasswordBox BorderThickness="0" Background="Transparent" FontSize="14" 
                                         Foreground="#111827" VerticalContentAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- New Password Field -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Новый пароль" FontSize="14" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,8"/>
                        <Border Background="#f3f4f6" CornerRadius="6" Padding="12,10">
                            <PasswordBox BorderThickness="0" Background="Transparent" FontSize="14" 
                                         Foreground="#111827" VerticalContentAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- Confirm Password Field -->
                    <StackPanel Margin="0,0,0,25">
                        <TextBlock Text="Подтверждение пароля" FontSize="14" FontWeight="SemiBold" Foreground="#374151" Margin="0,0,0,8"/>
                        <Border Background="#f3f4f6" CornerRadius="6" Padding="12,10">
                            <PasswordBox BorderThickness="0" Background="Transparent" FontSize="14" 
                                         Foreground="#111827" VerticalContentAlignment="Center"/>
                        </Border>
                    </StackPanel>

                    <!-- Change Password Button -->
                    <Button Content="Изменить пароль" Click="ChangePasswordButton_Click"
                            Background="#1a253a" Foreground="White" Padding="25,12" BorderThickness="0" 
                            FontWeight="SemiBold" FontSize="14" Cursor="Hand" HorizontalAlignment="Left">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
