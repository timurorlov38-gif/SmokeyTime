<Window x:Class="SmokeyTime.ReportsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smokey Time - Отчёты и аналитика"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#f9fafb">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1a253a" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo and Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="32" Height="32" Margin="0,0,12,0">
                        <Canvas Width="24" Height="24">
                            <Path Fill="White" 
                                  Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6Z"/>
                        </Canvas>
                    </Viewbox>
                    <StackPanel>
                        <TextBlock Text="Smokey Time" 
                                   FontSize="20" 
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Система автоматизации" 
                                   FontSize="12"
                                   Foreground="#9ca3af"/>
                    </StackPanel>
                </StackPanel>

                <!-- Navigation Menu -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="Панель управления" 
                            Background="Transparent"
                            Foreground="#d1d5db"
                            Padding="15,8"
                            Margin="5,0"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="5"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="Касса" 
                            Background="Transparent"
                            Foreground="#d1d5db"
                            Padding="15,8"
                            Margin="5,0"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="5"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="Склад" 
                            Background="Transparent"
                            Foreground="#d1d5db"
                            Padding="15,8"
                            Margin="5,0"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="5"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="Отчёты" 
                            Background="#374151"
                            Foreground="White"
                            Padding="15,8"
                            Margin="5,0"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="5"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="Настройки" 
                            Background="Transparent"
                            Foreground="#d1d5db"
                            Padding="15,8"
                            Margin="5,0"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="5"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- User Info -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,15,0" HorizontalAlignment="Right">
                        <TextBlock Text="Администратор" 
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock Text="Администратор" 
                                   FontSize="12"
                                   Foreground="#9ca3af"/>
                    </StackPanel>
                    <Border Background="White" 
                            CornerRadius="20" 
                            Width="40" 
                            Height="40"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="30,20">
            <StackPanel>
                <!-- Page Header & Period Selector -->
                <Grid Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Отчёты и аналитика" 
                                   FontSize="28" 
                                   FontWeight="Bold"
                                   Foreground="#111827"/>
                        <TextBlock Text="Анализ продаж и эффективности" 
                                   FontSize="14"
                                   Foreground="#6b7280"
                                   Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- Period Buttons -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Сегодня"
                                Background="#1a253a"
                                Foreground="White"
                                Padding="20,10"
                                Margin="5,0"
                                BorderThickness="0"
                                FontWeight="SemiBold"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="Неделя"
                                Background="White"
                                Foreground="#374151"
                                Padding="20,10"
                                Margin="5,0"
                                BorderThickness="1"
                                BorderBrush="#e5e7eb"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="Месяц"
                                Background="White"
                                Foreground="#374151"
                                Padding="20,10"
                                Margin="5,0"
                                BorderThickness="1"
                                BorderBrush="#e5e7eb"
                                Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" 
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="6"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Metrics Cards -->
                <Grid Margin="0,0,0,25">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Card 1: Revenue -->
                    <Border Grid.Column="0" 
                            Background="White" 
                            CornerRadius="10" 
                            Padding="25"
                            Margin="0,0,10,0"
                            BorderBrush="#e5e7eb"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Выручка" 
                                       FontSize="14"
                                       Foreground="#6b7280"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="0 ₽" 
                                       FontSize="32" 
                                       FontWeight="Bold"
                                       Foreground="#111827"/>
                            <TextBlock Text="0 продаж" 
                                       FontSize="13"
                                       Foreground="#9ca3af"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Card 2: Profit -->
                    <Border Grid.Column="1" 
                            Background="White" 
                            CornerRadius="10" 
                            Padding="25"
                            Margin="5,0"
                            BorderBrush="#e5e7eb"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Прибыль" 
                                       FontSize="14"
                                       Foreground="#6b7280"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="0 ₽" 
                                       FontSize="32" 
                                       FontWeight="Bold"
                                       Foreground="#10b981"/>
                            <TextBlock Text="Маржа: 0%" 
                                       FontSize="13"
                                       Foreground="#9ca3af"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Card 3: Cash -->
                    <Border Grid.Column="2" 
                            Background="White" 
                            CornerRadius="10" 
                            Padding="25"
                            Margin="5,0"
                            BorderBrush="#e5e7eb"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Наличные" 
                                       FontSize="14"
                                       Foreground="#6b7280"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="0 ₽" 
                                       FontSize="32" 
                                       FontWeight="Bold"
                                       Foreground="#111827"/>
                            <TextBlock Text="0% от выручки" 
                                       FontSize="13"
                                       Foreground="#9ca3af"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Card 4: Card -->
                    <Border Grid.Column="3" 
                            Background="White" 
                            CornerRadius="10" 
                            Padding="25"
                            Margin="10,0,0,0"
                            BorderBrush="#e5e7eb"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Безналичные" 
                                       FontSize="14"
                                       Foreground="#6b7280"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="0 ₽" 
                                       FontSize="32" 
                                       FontWeight="Bold"
                                       Foreground="#111827"/>
                            <TextBlock Text="0% от выручки" 
                                       FontSize="13"
                                       Foreground="#9ca3af"
                                       Margin="0,5,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Report Tabs -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Button Content="Продажи" 
                            Background="#e5e7eb"
                            Foreground="#111827"
                            Padding="20,10"
                            Margin="0,0,5,0"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="Топ товаров" 
                            Background="Transparent"
                            Foreground="#6b7280"
                            Padding="20,10"
                            Margin="5,0"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="АВС-анализ" 
                            Background="Transparent"
                            Foreground="#6b7280"
                            Padding="20,10"
                            Margin="5,0"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- Chart Area -->
                <Border Background="White" 
                        CornerRadius="10" 
                        Padding="25"
                        BorderBrush="#e5e7eb"
                        BorderThickness="1"
                        Height="400"
                        VerticalAlignment="Top">
                    <StackPanel>
                        <TextBlock Text="График продаж" 
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="#374151"
                                   Margin="0,0,0,20"/>

                        <!-- Placeholder for Chart -->
                        <Border Background="#f9fafb" 
                                CornerRadius="8" 
                                BorderBrush="#e5e7eb"
                                BorderThickness="1"
                                VerticalAlignment="Stretch">
                            <Grid>
                                <!-- Simple Grid Lines Simulation -->
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Border Grid.Row="0" BorderBrush="#e5e7eb" BorderThickness="0,0,0,1"/>
                                    <Border Grid.Row="1" BorderBrush="#e5e7eb" BorderThickness="0,0,0,1"/>
                                    <Border Grid.Row="2" BorderBrush="#e5e7eb" BorderThickness="0,0,0,1"/>
                                    <Border Grid.Row="3" BorderBrush="#e5e7eb" BorderThickness="0,0,0,1"/>
                                    <Border Grid.Row="4" BorderBrush="#e5e7eb" BorderThickness="0,0,0,1"/>
                                </Grid>

                                <TextBlock Text="Нет данных для отображения" 
                                           FontSize="14"
                                           Foreground="#9ca3af"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>