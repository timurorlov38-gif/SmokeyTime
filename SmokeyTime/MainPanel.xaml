<Window x:Class="SmokeyTime.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smokey Time - Панель управления"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#f9fafb">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1a253a" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo and Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="32" Height="32" Margin="0,0,12,0">
                        <Canvas Width="24" Height="24">
                            <Path Fill="White" 
                                  Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6Z"/>
                        </Canvas>
                    </Viewbox>
                    <StackPanel>
                        <TextBlock Text="Smokey Time" 
                                   FontSize="20" 
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Система автоматизации" 
                                   FontSize="12"
                                   Foreground="#9ca3af"/>
                    </StackPanel>
                </StackPanel>

                <!-- Navigation Menu -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="Панель управления" 
                            Background="#374151"
                            Foreground="White"
                            Padding="15,8"
                            Margin="5,0"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="5"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="Касса" 
                            Background="Transparent"
                            Foreground="#d1d5db"
                            Padding="15,8"
                            Margin="5,0"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="5"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="Склад" 
                            Background="Transparent"
                            Foreground="#d1d5db"
                            Padding="15,8"
                            Margin="5,0"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="5"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="Отчёты" 
                            Background="Transparent"
                            Foreground="#d1d5db"
                            Padding="15,8"
                            Margin="5,0"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="5"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="Настройки" 
                            Background="Transparent"
                            Foreground="#d1d5db"
                            Padding="15,8"
                            Margin="5,0"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="5"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- User Info -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,15,0">
                        <TextBlock Text="Администратор" 
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock Text="Администратор" 
                                   FontSize="12"
                                   Foreground="#9ca3af"/>
                    </StackPanel>
                    <Border Background="White" 
                            CornerRadius="20" 
                            Width="40" 
                            Height="40"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Border Grid.Row="1" Background="#f9fafb" Padding="30">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- Page Title -->
                    <StackPanel Margin="0,0,0,30">
                        <TextBlock Text="Панель управления" 
                                   FontSize="28" 
                                   FontWeight="Bold"
                                   Foreground="#111827"/>
                        <TextBlock Text="Обзор основных показателей магазина" 
                                   FontSize="14"
                                   Foreground="#6b7280"
                                   Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- Statistics Cards -->
                    <Grid Margin="0,0,0,30">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Card 1: Sales Today -->
                        <Border Grid.Column="0" 
                                Background="White" 
                                CornerRadius="10" 
                                Padding="20"
                                Margin="0,0,15,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" 
                                               Text="Продажи за сегодня" 
                                               FontSize="14"
                                               Foreground="#6b7280"
                                               VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" 
                                            Background="#dbeafe" 
                                            CornerRadius="8" 
                                            Width="32" 
                                            Height="32">
                                        <Viewbox Width="18" Height="18">
                                            <Canvas Width="24" Height="24">
                                                <Path Fill="#3b82f6" 
                                                      Data="M20,4H4A2,2 0 0,0 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V6A2,2 0 0,0 20,4M20,18H4V8L12,13L20,8V18M12,11L4,6H20L12,11Z"/>
                                            </Canvas>
                                        </Viewbox>
                                    </Border>
                                </Grid>
                                <TextBlock Text="2" 
                                           FontSize="32" 
                                           FontWeight="Bold"
                                           Foreground="#111827"/>
                            </StackPanel>
                        </Border>

                        <!-- Card 2: Revenue Today -->
                        <Border Grid.Column="1" 
                                Background="White" 
                                CornerRadius="10" 
                                Padding="20"
                                Margin="7.5,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" 
                                               Text="Выручка за сегодня" 
                                               FontSize="14"
                                               Foreground="#6b7280"
                                               VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" 
                                            Background="#d1fae5" 
                                            CornerRadius="8" 
                                            Width="32" 
                                            Height="32">
                                        <Viewbox Width="18" Height="18">
                                            <Canvas Width="24" Height="24">
                                                <Path Fill="#10b981" 
                                                      Data="M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22A10,10 0 0,1 2,12A10,10 0 0,1 12,2M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M11,14H13V16H11V14M12,7A2.5,2.5 0 0,1 14.5,9.5C14.5,11.43 11,12.24 11,13.5V14H13V13.5C13,12.89 13.58,12.5 14.08,12.29C14.93,11.93 15.5,11.39 15.5,10.5A3.5,3.5 0 0,0 12,7Z"/>
                                            </Canvas>
                                        </Viewbox>
                                    </Border>
                                </Grid>
                                <TextBlock Text="47 200 ₽" 
                                           FontSize="32" 
                                           FontWeight="Bold"
                                           Foreground="#111827"/>
                            </StackPanel>
                        </Border>

                        <!-- Card 3: Products in Stock -->
                        <Border Grid.Column="2" 
                                Background="White" 
                                CornerRadius="10" 
                                Padding="20"
                                Margin="7.5,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" 
                                               Text="Товаров в наличии" 
                                               FontSize="14"
                                               Foreground="#6b7280"
                                               VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" 
                                            Background="#f3e8ff" 
                                            CornerRadius="8" 
                                            Width="32" 
                                            Height="32">
                                        <Viewbox Width="18" Height="18">
                                            <Canvas Width="24" Height="24">
                                                <Path Fill="#a855f7" 
                                                      Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L6.04,7.5L12,10.85L17.96,7.5L12,4.15M5,15.91L11,19.29V12.58L5,9.21V15.91M19,15.91V9.21L13,12.58V19.29L19,15.91Z"/>
                                            </Canvas>
                                        </Viewbox>
                                    </Border>
                                </Grid>
                                <TextBlock Text="6" 
                                           FontSize="32" 
                                           FontWeight="Bold"
                                           Foreground="#111827"/>
                            </StackPanel>
                        </Border>

                        <!-- Card 4: Low Stock -->
                        <Border Grid.Column="3" 
                                Background="White" 
                                CornerRadius="10" 
                                Padding="20"
                                Margin="15,0,0,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" 
                                               Text="Низкий остаток" 
                                               FontSize="14"
                                               Foreground="#6b7280"
                                               VerticalAlignment="Center"/>
                                    <Border Grid.Column="1" 
                                            Background="#ffedd5" 
                                            CornerRadius="8" 
                                            Width="32" 
                                            Height="32">
                                        <Viewbox Width="18" Height="18">
                                            <Canvas Width="24" Height="24">
                                                <Path Fill="#f97316" 
                                                      Data="M12,2L1,21H23M12,6L19.53,19H4.47"/>
                                            </Canvas>
                                        </Viewbox>
                                    </Border>
                                </Grid>
                                <TextBlock Text="0" 
                                           FontSize="32" 
                                           FontWeight="Bold"
                                           Foreground="#111827"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Quick Actions -->
                    <Border Background="White" 
                            CornerRadius="10" 
                            Padding="25">
                        <StackPanel>
                            <TextBlock Text="Быстрые действия" 
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#374151"
                                       Margin="0,0,0,20"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <!-- Action 1: Open Cash Register -->
                                <Border Grid.Column="0" 
                                        Background="#f9fafb" 
                                        CornerRadius="8" 
                                        Padding="20"
                                        Margin="0,0,10,0"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="OpenCashRegisterButton_Click">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#f9fafb"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#f3f4f6"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <Border Background="#dbeafe" 
                                                CornerRadius="8" 
                                                Width="40" 
                                                Height="40"
                                                HorizontalAlignment="Left"
                                                Margin="0,0,0,12">
                                            <Viewbox Width="22" Height="22">
                                                <Canvas Width="24" Height="24">
                                                    <Path Fill="#3b82f6" 
                                                          Data="M19,19H5V5H19M19,3H5A2,2 0 0,0 3,5V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V5A2,2 0 0,0 19,3M13.96,12.29L11.21,15.83L9.25,13.47L6.5,17H19.5L13.96,12.29Z"/>
                                                </Canvas>
                                            </Viewbox>
                                        </Border>
                                        <TextBlock Text="Открыть кассу" 
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="#111827"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Начать новую смену" 
                                                   FontSize="13"
                                                   Foreground="#6b7280"/>
                                    </StackPanel>
                                </Border>

                                <!-- Action 2: Warehouse Management -->
                                <Border Grid.Column="1" 
                                        Background="#f9fafb" 
                                        CornerRadius="8" 
                                        Padding="20"
                                        Margin="5,0"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="WarehouseManagementButton_Click">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#f9fafb"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#f3f4f6"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <Border Background="#f3e8ff" 
                                                CornerRadius="8" 
                                                Width="40" 
                                                Height="40"
                                                HorizontalAlignment="Left"
                                                Margin="0,0,0,12">
                                            <Viewbox Width="22" Height="22">
                                                <Canvas Width="24" Height="24">
                                                    <Path Fill="#a855f7" 
                                                          Data="M21,16.5C21,16.88 20.79,17.21 20.47,17.38L12.57,21.82C12.41,21.94 12.21,22 12,22C11.79,22 11.59,21.94 11.43,21.82L3.53,17.38C3.21,17.21 3,16.88 3,16.5V7.5C3,7.12 3.21,6.79 3.53,6.62L11.43,2.18C11.59,2.06 11.79,2 12,2C12.21,2 12.41,2.06 12.57,2.18L20.47,6.62C20.79,6.79 21,7.12 21,7.5V16.5M12,4.15L6.04,7.5L12,10.85L17.96,7.5L12,4.15M5,15.91L11,19.29V12.58L5,9.21V15.91M19,15.91V9.21L13,12.58V19.29L19,15.91Z"/>
                                                </Canvas>
                                            </Viewbox>
                                        </Border>
                                        <TextBlock Text="Управление складом" 
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="#111827"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Приёмка и учёт товаров" 
                                                   FontSize="13"
                                                   Foreground="#6b7280"/>
                                    </StackPanel>
                                </Border>

                                <!-- Action 3: Reports -->
                                <Border Grid.Column="2" 
                                        Background="#f9fafb" 
                                        CornerRadius="8" 
                                        Padding="20"
                                        Margin="10,0,0,0"
                                        Cursor="Hand"
                                        MouseLeftButtonUp="ReportsAnalyticsButton_Click">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#f9fafb"/>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#f3f4f6"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <Border Background="#d1fae5" 
                                                CornerRadius="8" 
                                                Width="40" 
                                                Height="40"
                                                HorizontalAlignment="Left"
                                                Margin="0,0,0,12">
                                            <Viewbox Width="22" Height="22">
                                                <Canvas Width="24" Height="24">
                                                    <Path Fill="#10b981" 
                                                          Data="M16,6L18.29,8.29L13.41,13.17L9.41,9.17L2,16.59L3.41,18L9.41,12L13.41,16L19.71,9.71L22,12V6H16Z"/>
                                                </Canvas>
                                            </Viewbox>
                                        </Border>
                                        <TextBlock Text="Отчёты" 
                                                   FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="#111827"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Text="Аналитика продаж" 
                                                   FontSize="13"
                                                   Foreground="#6b7280"/>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>