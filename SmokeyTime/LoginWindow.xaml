<Window x:Class="SmokeyTime.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smokey Time - Авторизация"
        Height="600" Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1a253a">

    <Grid>
        <Border Background="White" 
                CornerRadius="10" 
                Margin="100,50"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">

            <StackPanel Margin="40,30" HorizontalAlignment="Center">

                <!-- Logo Icon -->
                <Viewbox Width="60" Height="60" Margin="0,0,0,20">
                    <Canvas Width="24" Height="24">
                        <Path Fill="#1a253a" 
                              Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6Z"/>
                    </Canvas>
                </Viewbox>

                <!-- Title -->
                <TextBlock Text="Smokey Time" 
                           FontSize="32" 
                           FontWeight="Bold"
                           Foreground="#1a253a"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,10"/>

                <!-- Subtitle -->
                <TextBlock Text="Система автоматизации розничной торговли" 
                           FontSize="14"
                           Foreground="#6b7280"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,30"/>

                <!-- Login Label -->
                <TextBlock Text="Логин" 
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#374151"
                           Margin="0,0,0,8"/>

                <!-- Login TextBox -->
                <Border Background="#f3f4f6" 
                        CornerRadius="5" 
                        Padding="12,10"
                        Margin="0,0,0,20">
                    <TextBox x:Name="LoginTextBox"
                             BorderThickness="0"
                             Background="Transparent"
                             FontSize="14"
                             Foreground="#374151"
                             VerticalContentAlignment="Center"/>
                </Border>

                <!-- Password Label -->
                <TextBlock Text="Пароль" 
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#374151"
                           Margin="0,0,0,8"/>

                <!-- Password TextBox -->
                <Border Background="#f3f4f6" 
                        CornerRadius="5" 
                        Padding="12,10"
                        Margin="0,0,0,25">
                    <PasswordBox x:Name="PasswordBox"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 FontSize="14"
                                 Foreground="#374151"
                                 VerticalContentAlignment="Center"/>
                </Border>

                <!-- Login Button -->
                <Button Content="Войти"
        Height="45"
        Background="#1a253a"
        Foreground="White"
        FontSize="16"
        FontWeight="SemiBold"
        BorderThickness="0"
        Cursor="Hand"
        Margin="0,0,0,20"
        Click="LoginButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                    CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" 
                                  VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</Window>