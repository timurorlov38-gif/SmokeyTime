<Window x:Class="SmokeyTime.POSWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smokey Time - Касса (POS)"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#f9fafb">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header с навигацией -->
        <Border Grid.Row="0" Background="#1a253a" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="32" Height="32" Margin="0,0,12,0">
                        <Canvas Width="24" Height="24">
                            <Path Fill="White" Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6Z"/>
                        </Canvas>
                    </Viewbox>
                    <StackPanel>
                        <TextBlock Text="Smokey Time" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Система автоматизации" FontSize="12" Foreground="#9ca3af"/>
                    </StackPanel>
                </StackPanel>

                <!-- Navigation Menu -->
                <StackPanel x:Name="NavigationPanel" Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="Панель управления" Click="NavButton_Click"
                            Background="Transparent" Foreground="#d1d5db" Padding="15,8" Margin="5,0" BorderThickness="0" Cursor="Hand" FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="Касса" Click="NavButton_Click"
                            Background="#374151" Foreground="White" Padding="15,8" Margin="5,0" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="Склад" Click="NavButton_Click"
                            Background="Transparent" Foreground="#d1d5db" Padding="15,8" Margin="5,0" BorderThickness="0" Cursor="Hand" FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="Отчёты" Click="NavButton_Click"
                            Background="Transparent" Foreground="#d1d5db" Padding="15,8" Margin="5,0" BorderThickness="0" Cursor="Hand" FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="Настройки" Click="NavButton_Click"
                            Background="Transparent" Foreground="#d1d5db" Padding="15,8" Margin="5,0" BorderThickness="0" Cursor="Hand" FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- Close Session Button -->
                <Button Grid.Column="2" Content="Закрыть смену" Click="CloseSessionButton_Click"
                        Background="#ef4444" Foreground="White" Padding="20,10" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" FontSize="14">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" CornerRadius="5" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="30,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="400"/>
            </Grid.ColumnDefinitions>

            <!-- Left Side - Products -->
            <StackPanel Grid.Column="0">
                <!-- Page Title -->
                <StackPanel Margin="0,0,0,20">
                    <TextBlock Text="Касса (POS)" FontSize="28" FontWeight="Bold" Foreground="#111827"/>
                    <TextBlock x:Name="SessionInfoText" Text="Смена открыта: 02.03.2026, 14:22:55" FontSize="14" Foreground="#6b7280" Margin="0,5,0,0"/>
                </StackPanel>

                <!-- Search Bar -->
                <Border Background="White" CornerRadius="8" Padding="15,12" Margin="0,0,0,25" BorderBrush="#e5e7eb" BorderThickness="1">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Viewbox Grid.Column="0" Width="20" Height="20" Margin="0,0,10,0">
                            <Canvas Width="24" Height="24">
                                <Path Fill="#9ca3af" Data="M9.5,3A6.5,6.5 0 0,1 16,9.5C16,11.11 15.41,12.59 14.44,13.73L14.71,14H15.5L20.5,19L19,20.5L14,15.5V14.71L13.73,14.44C12.59,15.41 11.11,16 9.5,16A6.5,6.5 0 0,1 3,9.5A6.5,6.5 0 0,1 9.5,3M9.5,5C7,5 5,7 5,9.5C5,12 7,14 9.5,14C12,14 14,12 14,9.5C14,7 12,5 9.5,5Z"/>
                            </Canvas>
                        </Viewbox>
                        <TextBox x:Name="SearchTextBox" Grid.Column="1" BorderThickness="0" Background="Transparent" FontSize="14" Foreground="#374151" VerticalContentAlignment="Center" Text="Поиск по названию или штрихкоду..."/>
                    </Grid>
                </Border>

                <!-- Products Grid -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Product 1 -->
                    <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="20" Margin="0,0,10,15" BorderBrush="#e5e7eb" BorderThickness="1">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Жидкость HQD" FontSize="16" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,4"/>
                                    <TextBlock Text="4627001234569" FontSize="12" Foreground="#9ca3af"/>
                                </StackPanel>
                                <Border Grid.Column="1" Background="#ef4444" CornerRadius="4" Padding="6,3">
                                    <TextBlock Text="18+" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </Grid>
                            <Border Background="#f3f4f6" CornerRadius="6" Padding="10,8" Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="Выберите вариацию" FontSize="13" Foreground="#6b7280" VerticalAlignment="Center"/>
                                    <Viewbox Grid.Column="1" Width="16" Height="16">
                                        <Canvas Width="24" Height="24">
                                            <Path Fill="#6b7280" Data="M7.41,8.58L12,13.17L16.59,8.58L18,10L12,16L6,10L7.41,8.58Z"/>
                                        </Canvas>
                                    </Viewbox>
                                </Grid>
                            </Border>
                            <TextBlock Text="350 ₽" FontSize="24" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,8"/>
                            <TextBlock Text="Остаток: 49 шт" FontSize="13" Foreground="#6b7280" Margin="0,0,0,15"/>
                            <Button Content="+ В чек" Click="AddToCartButton_Click"
                                    Background="#1a253a" Foreground="White" Padding="15,8" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" HorizontalAlignment="Right">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Product 2 -->
                    <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="20" Margin="10,0,0,15" BorderBrush="#e5e7eb" BorderThickness="1">
                        <StackPanel>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Уголь кокосовый" FontSize="16" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,4"/>
                                    <TextBlock Text="4627001234570" FontSize="12" Foreground="#9ca3af"/>
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="450 ₽" FontSize="24" FontWeight="Bold" Foreground="#111827" Margin="0,0,0,8"/>
                            <TextBlock Text="Остаток: 39 шт" FontSize="13" Foreground="#6b7280" Margin="0,0,0,15"/>
                            <Button Content="+ В чек" Click="AddToCartButton_Click"
                                    Background="#1a253a" Foreground="White" Padding="15,8" BorderThickness="0" FontWeight="SemiBold" Cursor="Hand" HorizontalAlignment="Right">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </StackPanel>
                    </Border>
                </Grid>
            </StackPanel>

            <!-- Right Side - Cart and Statistics -->
            <StackPanel Grid.Column="1" Margin="20,0,0,0">

                <!-- Current Receipt -->
                <Border Background="White" CornerRadius="10" Padding="25" Margin="0,0,0,20" BorderBrush="#e5e7eb" BorderThickness="1">
                    <StackPanel>
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Viewbox Grid.Column="0" Width="24" Height="24" Margin="0,0,10,0">
                                <Canvas Width="24" Height="24">
                                    <Path Fill="#1a253a" Data="M17,18C15.89,18 15,18.89 15,20A2,2 0 0,0 17,22A2,2 0 0,0 19,20C19,18.89 18.1,18 17,18M1,2V4H3L6.6,11.59L5.24,14.04C5.09,14.32 5,14.65 5,15A2,2 0 0,0 7,17H19V15H7.42A0.25,0.25 0 0,1 7.17,14.75C7.17,14.7 7.18,14.66 7.2,14.63L8.1,13H15.55C16.3,13 16.96,12.59 17.3,11.97L21,5H7L5.21,1.59C5.05,1.28 4.73,1.09 4.38,1.09H2V2M7,18C5.89,18 5,18.89 5,20A2,2 0 0,0 7,22A2,2 0 0,0 9,20C9,18.89 8.1,18 7,18Z"/>
                                </Canvas>
                            </Viewbox>
                            <TextBlock Grid.Column="1" Text="Текущий чек" FontSize="18" FontWeight="SemiBold" Foreground="#111827" VerticalAlignment="Center"/>
                        </Grid>

                        <Border x:Name="CartContent" Background="#f9fafb" CornerRadius="8" Padding="30,40" Margin="0,0,0,10">
                            <TextBlock x:Name="CartText" Text="Корзина пуста" FontSize="16" Foreground="#9ca3af" HorizontalAlignment="Center"/>
                        </Border>

                        <!-- Checkout Button -->
                        <Button x:Name="CheckoutButton" Content="Оплатить" Click="CheckoutButton_Click"
                                Background="#10b981" Foreground="White" Height="45" BorderThickness="0" FontWeight="SemiBold" FontSize="16" Cursor="Hand" Visibility="Collapsed">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Session Statistics -->
                <Border Background="White" CornerRadius="10" Padding="25" BorderBrush="#e5e7eb" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Статистика смены" FontSize="18" FontWeight="SemiBold" Foreground="#111827" Margin="0,0,0,20"/>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Начальная сумма:" FontSize="14" Foreground="#6b7280"/>
                            <TextBlock Grid.Column="1" Text="70 000 ₽" FontSize="14" FontWeight="SemiBold" Foreground="#111827"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Продажи:" FontSize="14" Foreground="#6b7280"/>
                            <TextBlock Grid.Column="1" Text="47 200 ₽" FontSize="14" FontWeight="SemiBold" Foreground="#111827"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Наличные:" FontSize="14" Foreground="#6b7280"/>
                            <TextBlock Grid.Column="1" Text="34 000 ₽" FontSize="14" FontWeight="SemiBold" Foreground="#111827"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="Безнал:" FontSize="14" Foreground="#6b7280"/>
                            <TextBlock Grid.Column="1" Text="13 200 ₽" FontSize="14" FontWeight="SemiBold" Foreground="#111827"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>
    </Grid>
</Window>