                            <TextBlock Grid.Column="3" Text="2 500 ₽" FontSize="14" FontWeight="SemiBold" Foreground="#111827" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="1 800 ₽" FontSize="14" Foreground="#6b7280" VerticalAlignment="Center"/>
                            <Border Grid.Column="5" Background="#f3f4f6" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left">
                                <TextBlock Text="11 шт." FontSize="13" Foreground="#374151"/>
                            </Border>
                            <TextBlock Grid.Column="6" Text="5 шт." FontSize="14" Foreground="#6b7280" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="7" Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Background="Transparent" BorderThickness="0" Padding="5" Cursor="Hand" Margin="0,0,5,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
