<Window x:Class="SmokeyTime.WarehouseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Smokey Time - Склад и инвентаризация"
        Height="720" Width="1280"
        WindowStartupLocation="CenterScreen"
        Background="#f9fafb">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#1a253a" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo and Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Viewbox Width="32" Height="32" Margin="0,0,12,0">
                        <Canvas Width="24" Height="24">
                            <Path Fill="White" 
                                  Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6Z"/>
                        </Canvas>
                    </Viewbox>
                    <StackPanel>
                        <TextBlock Text="Smokey Time" 
                                   FontSize="20" 
                                   FontWeight="Bold"
                                   Foreground="White"/>
                        <TextBlock Text="Система автоматизации" 
                                   FontSize="12"
                                   Foreground="#9ca3af"/>
                    </StackPanel>
                </StackPanel>

                <!-- Navigation Menu -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Content="Панель управления" 
                            Background="Transparent"
                            Foreground="#d1d5db"
                            Padding="15,8"
                            Margin="5,0"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="5"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="Касса" 
                            Background="Transparent"
                            Foreground="#d1d5db"
                            Padding="15,8"
                            Margin="5,0"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="5"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="Склад" 
                            Background="#374151"
                            Foreground="White"
                            Padding="15,8"
                            Margin="5,0"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="5"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="Отчёты" 
                            Background="Transparent"
                            Foreground="#d1d5db"
                            Padding="15,8"
                            Margin="5,0"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="5"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="Настройки" 
                            Background="Transparent"
                            Foreground="#d1d5db"
                            Padding="15,8"
                            Margin="5,0"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="5"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- User Info -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <StackPanel Margin="0,0,15,0" HorizontalAlignment="Right">
                        <TextBlock Text="Администратор" 
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>
                        <TextBlock Text="Администратор" 
                                   FontSize="12"
                                   Foreground="#9ca3af"/>
                    </StackPanel>
                    <Border Background="White" 
                            CornerRadius="20" 
                            Width="40" 
                            Height="40"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1" Margin="30,20">
            <StackPanel>
                <!-- Page Title -->
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Склад и инвентаризация" 
                                   FontSize="28" 
                                   FontWeight="Bold"
                                   Foreground="#111827"/>
                        <TextBlock Text="Управление товарными запасами" 
                                   FontSize="14"
                                   Foreground="#6b7280"
                                   Margin="0,5,0,0"/>
                    </StackPanel>

                    <Button Grid.Column="1" 
                            Content="+ Добавить товар"
                            Background="#1a253a"
                            Foreground="White"
                            Padding="20,10"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- Tabs -->
                <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                    <Button Content="Номенклатура" 
                            Background="#e5e7eb"
                            Foreground="#111827"
                            Padding="20,10"
                            Margin="0,0,5,0"
                            BorderThickness="0"
                            FontWeight="SemiBold"
                            Cursor="Hand"
                            FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="Приёмка" 
                            Background="Transparent"
                            Foreground="#6b7280"
                            Padding="20,10"
                            Margin="5,0"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <Button Content="Списание" 
                            Background="Transparent"
                            Foreground="#6b7280"
                            Padding="20,10"
                            Margin="5,0"
                            BorderThickness="0"
                            Cursor="Hand"
                            FontSize="14">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" 
                                        CornerRadius="6"
                                        Padding="{TemplateBinding Padding}">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>

                <!-- Products Table -->
                <Border Background="White" 
                        CornerRadius="10" 
                        Padding="25"
                        BorderBrush="#e5e7eb"
                        BorderThickness="1">
                    <StackPanel>
                        <!-- Table Header -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Название" FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
                            <TextBlock Grid.Column="1" Text="Категория" FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
                            <TextBlock Grid.Column="2" Text="Штрихкод" FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
                            <TextBlock Grid.Column="3" Text="Цена" FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
                            <TextBlock Grid.Column="4" Text="Себестоимость" FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
                            <TextBlock Grid.Column="5" Text="Остаток" FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
                            <TextBlock Grid.Column="6" Text="Мин. остаток" FontSize="13" FontWeight="SemiBold" Foreground="#374151"/>
                            <TextBlock Grid.Column="7" Text="Действия" FontSize="13" FontWeight="SemiBold" Foreground="#374151" HorizontalAlignment="Center"/>
                        </Grid>

                        <!-- Separator -->
                        <Border Height="1" Background="#e5e7eb" Margin="0,0,0,15"/>

                        <!-- Product 1 -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="Кальян Amy Deluxe" FontSize="14" Foreground="#111827" VerticalAlignment="Center"/>
                                <Border Background="#ef4444" CornerRadius="4" Padding="6,2" Margin="8,0,0,0">
                                    <TextBlock Text="18+" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="Кальяны" FontSize="14" Foreground="#6b7280" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="4627001234567" FontSize="14" Foreground="#6b7280" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="8 500 ₽" FontSize="14" FontWeight="SemiBold" Foreground="#111827" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="6 000 ₽" FontSize="14" Foreground="#6b7280" VerticalAlignment="Center"/>
                            <Border Grid.Column="5" Background="#f3f4f6" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left">
                                <TextBlock Text="18 шт." FontSize="13" Foreground="#374151"/>
                            </Border>
                            <TextBlock Grid.Column="6" Text="2 шт." FontSize="14" Foreground="#6b7280" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="7" Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Background="Transparent" BorderThickness="0" Padding="5" Cursor="Hand" Margin="0,0,5,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}">
                                                <Viewbox Width="18" Height="18">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Fill="#3b82f6" Data="M20,18V22H4V18M20,6A2,2 0 0,0 18,4H6A2,2 0 0,0 4,6V16A2,2 0 0,0 6,18H18A2,2 0 0,0 20,16V6M12,11A2,2 0 0,1 10,9A2,2 0 0,1 12,7A2,2 0 0,1 14,9A2,2 0 0,1 12,11Z"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Background="Transparent" BorderThickness="0" Padding="5" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}">
                                                <Viewbox Width="18" Height="18">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Fill="#ef4444" Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- Product 2 -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="Табак Darkside" FontSize="14" Foreground="#111827" VerticalAlignment="Center"/>
                                <Border Background="#ef4444" CornerRadius="4" Padding="6,2" Margin="8,0,0,0">
                                    <TextBlock Text="18+" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="Табак" FontSize="14" Foreground="#6b7280" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="4627001234568" FontSize="14" Foreground="#6b7280" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="1 200 ₽" FontSize="14" FontWeight="SemiBold" Foreground="#111827" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="800 ₽" FontSize="14" Foreground="#6b7280" VerticalAlignment="Center"/>
                            <Border Grid.Column="5" Background="#f3f4f6" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left">
                                <TextBlock Text="24 шт." FontSize="13" Foreground="#374151"/>
                            </Border>
                            <TextBlock Grid.Column="6" Text="10 шт." FontSize="14" Foreground="#6b7280" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="7" Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Background="Transparent" BorderThickness="0" Padding="5" Cursor="Hand" Margin="0,0,5,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}">
                                                <Viewbox Width="18" Height="18">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Fill="#3b82f6" Data="M20,18V22H4V18M20,6A2,2 0 0,0 18,4H6A2,2 0 0,0 4,6V16A2,2 0 0,0 6,18H18A2,2 0 0,0 20,16V6M12,11A2,2 0 0,1 10,9A2,2 0 0,1 12,7A2,2 0 0,1 14,9A2,2 0 0,1 12,11Z"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Background="Transparent" BorderThickness="0" Padding="5" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}">
                                                <Viewbox Width="18" Height="18">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Fill="#ef4444" Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- Product 3 -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="Жидкость HQD" FontSize="14" Foreground="#111827" VerticalAlignment="Center"/>
                                <Border Background="#ef4444" CornerRadius="4" Padding="6,2" Margin="8,0,0,0">
                                    <TextBlock Text="18+" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="Жидкости" FontSize="14" Foreground="#6b7280" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="4627001234569" FontSize="14" Foreground="#6b7280" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="350 ₽" FontSize="14" FontWeight="SemiBold" Foreground="#111827" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="200 ₽" FontSize="14" Foreground="#6b7280" VerticalAlignment="Center"/>
                            <Border Grid.Column="5" Background="#f3f4f6" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left">
                                <TextBlock Text="49 шт." FontSize="13" Foreground="#374151"/>
                            </Border>
                            <TextBlock Grid.Column="6" Text="20 шт." FontSize="14" Foreground="#6b7280" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="7" Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Background="Transparent" BorderThickness="0" Padding="5" Cursor="Hand" Margin="0,0,5,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}">
                                                <Viewbox Width="18" Height="18">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Fill="#3b82f6" Data="M20,18V22H4V18M20,6A2,2 0 0,0 18,4H6A2,2 0 0,0 4,6V16A2,2 0 0,0 6,18H18A2,2 0 0,0 20,16V6M12,11A2,2 0 0,1 10,9A2,2 0 0,1 12,7A2,2 0 0,1 14,9A2,2 0 0,1 12,11Z"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Background="Transparent" BorderThickness="0" Padding="5" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}">
                                                <Viewbox Width="18" Height="18">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Fill="#ef4444" Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- Product 4 -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="Уголь кокосовый" FontSize="14" Foreground="#111827" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="Уголь" FontSize="14" Foreground="#6b7280" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="4627001234570" FontSize="14" Foreground="#6b7280" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="450 ₽" FontSize="14" FontWeight="SemiBold" Foreground="#111827" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="4" Text="250 ₽" FontSize="14" Foreground="#6b7280" VerticalAlignment="Center"/>
                            <Border Grid.Column="5" Background="#f3f4f6" CornerRadius="4" Padding="8,4" HorizontalAlignment="Left">
                                <TextBlock Text="39 шт." FontSize="13" Foreground="#374151"/>
                            </Border>
                            <TextBlock Grid.Column="6" Text="15 шт." FontSize="14" Foreground="#6b7280" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="7" Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Background="Transparent" BorderThickness="0" Padding="5" Cursor="Hand" Margin="0,0,5,0">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}">
                                                <Viewbox Width="18" Height="18">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Fill="#3b82f6" Data="M20,18V22H4V18M20,6A2,2 0 0,0 18,4H6A2,2 0 0,0 4,6V16A2,2 0 0,0 6,18H18A2,2 0 0,0 20,16V6M12,11A2,2 0 0,1 10,9A2,2 0 0,1 12,7A2,2 0 0,1 14,9A2,2 0 0,1 12,11Z"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                                <Button Background="Transparent" BorderThickness="0" Padding="5" Cursor="Hand">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}">
                                                <Viewbox Width="18" Height="18">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Fill="#ef4444" Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"/>
                                                    </Canvas>
                                                </Viewbox>
                                            </Border>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <!-- Product 5 -->
                        <Grid Margin="0,0,0,15">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="150"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="100"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="POD система JUUL" FontSize="14" Foreground="#111827" VerticalAlignment="Center"/>
                                <Border Background="#ef4444" CornerRadius="4" Padding="6,2" Margin="8,0,0,0">
                                    <TextBlock Text="18+" FontSize="11" FontWeight="Bold" Foreground="White"/>
                                </Border>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="POD-системы" FontSize="14" Foreground="#6b7280" VerticalAlignment="Center"/>
